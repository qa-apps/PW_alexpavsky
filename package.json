{
  "name": "pw_alexpavsky",
  "version": "1.0.0",
  "description": "Playwright end-to-end test suite for alexpavsky.com.",
  "scripts": {
    "init:agents": "playwright init-agents --loop=vscode --prompts",
    "test": "playwright test",
    "test:headed": "playwright test --headed",
    "test:chromium": "playwright test --project=chromium",
    "test:debug": "playwright test --debug",
    "test:smoke": "playwright test tests/smoke/ --workers=1",
    "test:smoke:headed": "playwright test tests/smoke/ --workers=1 --headed",
    "test:ui": "playwright test tests/loginDashboard.spec.ts --workers=1",
    "test:ui:headed": "playwright test tests/loginDashboard.spec.ts --workers=1 --headed",
    "test:security": "playwright test tests/securityVulnerability.spec.ts --workers=1",
    "test:security:headed": "playwright test tests/securityVulnerability.spec.ts --workers=1 --headed",
    "report": "playwright show-report",
    "mcp:playwright": "playwright-mcp --headless --browser chrome --output-dir .playwright-mcp --save-trace --save-session",
    "performance": "k6 run performance/site.js",
    "performance:load": "k6 run -e PERFORMANCE_SCENARIO=load performance/site.js",
    "performance:spike:slow": "k6 run -e PERFORMANCE_SCENARIO=spike-slow performance/site.js",
    "performance:spike:instant": "k6 run -e PERFORMANCE_SCENARIO=spike-instant performance/site.js",
    "eval": "promptfoo eval --no-cache --max-concurrency 1",
    "eval:static": "promptfoo eval --no-cache --max-concurrency 1",
    "eval:view": "promptfoo view",
    "providers:refresh": "ts-node scripts/refresh-promptfoo-providers.ts",
    "providers:ping": "ts-node scripts/ping-providers.ts"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/qa-apps/PW_alexpavsky.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/qa-apps/PW_alexpavsky/issues"
  },
  "homepage": "https://github.com/qa-apps/PW_alexpavsky#readme",
  "devDependencies": {
    "@playwright/mcp": "^0.0.68",
    "@playwright/test": "^1.58.2",
    "@types/node": "^25.5.0",
    "dotenv": "^17.3.1",
    "eslint": "^10.1.0",
    "promptfoo": "^0.121.3",
    "typescript": "^5.9.3"
  }
}
